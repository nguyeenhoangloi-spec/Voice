# ============================================================
# VoiceAI — .gitignore
# ============================================================

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# ─── Virtual Environments ────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Testing & Coverage ──────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc
.tox/

# ─── Type Checking ───────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyright/

# ─── Secrets & Environment Variables ─────────────────────────
# NEVER commit .env — store secrets in .env.example only
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Database ────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
storage/database.db

# ─── Storage — User-generated media ──────────────────────────
storage/uploads/*
storage/temp/*
storage/audio/*
storage/video/*
storage/subtitles/*
storage/exports/*
storage/models/*

# Keep directory stubs for git (do not ignore .gitkeep files)
!storage/uploads/.gitkeep
!storage/temp/.gitkeep
!storage/audio/.gitkeep
!storage/video/.gitkeep
!storage/subtitles/.gitkeep
!storage/exports/.gitkeep
!storage/models/.gitkeep

# Keep sample files
!storage/samples/

# ─── Binary / Large Files ────────────────────────────────────
# FFmpeg/FFprobe executables — download separately, don't commit
binaries/*.exe
binaries/*.dll
binaries/ffmpeg
binaries/ffprobe

# ─── Logs ────────────────────────────────────────────────────
*.log
*.log.*
logs/
server.log
error.log

# ─── Node / JS ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── IDE & Editor ────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
.project
.classpath

# ─── OS Generated ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Agent / AI IDE configs ──────────────────────────────────
# Keep GEMINI.md (project rules) but ignore agent internals
.agent/
!GEMINI.md

# ─── Alembic ─────────────────────────────────────────────────
# Keep alembic config but ignore generated migration scripts if using auto-gen
# alembic/versions/  # Uncomment if you auto-generate versions locally

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
